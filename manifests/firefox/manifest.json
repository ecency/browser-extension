{
  "name": "__MSG_keychain__",
  "description": "__MSG_description__",
  "default_locale": "en",
  "version": "3.16.0",
  "permissions": ["storage", "idle", "alarms"],
  "content_security_policy": "script-src 'self'; object-src 'self';",
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "/assets/images/iconhive.png"
  },
  "icons": { "128": "/assets/images/iconhive.png" },
  "background": { "scripts": ["backgroundBundle.js"], "persistent": true },
  "web_accessible_resources": ["/images/logo.png", "hive.js"],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://0.0.0.0:1337/*", "http://*/*"],
      "js": ["web_interfaceBundle.js"],
      "all_frames": true
    }
  ],
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "{c295b428-dcac-45aa-ac4c-bc8a5e1bd8f6}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
